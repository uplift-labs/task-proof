# Runtime TypeScript and text artifacts are consumed across Windows,
# Linux, and macOS. Keep committed text normalized to LF.
*.ts      text eol=lf
*.json    text eol=lf
*.toml    text eol=lf
*.md      text eol=lf
*.tmpl    text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
LICENSE         text eol=lf
CONTRACT.md     text eol=lf
