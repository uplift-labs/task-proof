        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.task-proof/adapter/hooks/pre-bash.sh\"",
            "timeout": 135000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
